{
  "manifest_version": 3,
  "name": "RYM Collector",
  "version": "1.0.0",
  "description": "Passively collect RateYourMusic album data as you browse",
  "permissions": ["activeTab"],
  "host_permissions": ["*://rateyourmusic.com/*"],
  "content_scripts": [
    {
      "matches": ["https://rateyourmusic.com/release/album/*/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://rateyourmusic.com/artist/*"],
      "js": ["content_artist.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "RYM Collector"
  }
}
